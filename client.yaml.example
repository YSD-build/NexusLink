# ========================================
# NexusLink 客户端配置文件 v0.2.0.beta
# ========================================

# 服务端IP
server_ip: 你的服务器IP

# 服务端端口
server_port: 7000

# 认证密钥（必须与服务端一致）
token: your_secret_token_here

# ========================================
# 端口映射配置（常用模板）
# ========================================
proxies:
  # ------------------------------------
  # Minecraft 服务器 (25565)
  # ------------------------------------
  mc:
    type: tcp
    port: 25565
    localaddr: 127.0.0.1
    localport: 25565

  # ------------------------------------  
  # SSH 远程连接 (22)
  # ------------------------------------
  ssh:
    type: tcp
    port: 6000
    localaddr: 127.0.0.1
    localport: 22

  # ------------------------------------
  # Web 网站 (80)
  # ------------------------------------
  web:
    type: tcp
    port: 8080
    localaddr: 127.0.0.1
    localport: 80

  # ------------------------------------
  # HTTPS (443)
  # ------------------------------------
  https:
    type: tcp
    port: 8443
    localaddr: 127.0.0.1
    localport: 443

  # ------------------------------------
  # RDP 远程桌面 (3389)
  # ------------------------------------
  rdp:
    type: tcp
    port: 3389
    localaddr: 127.0.0.1
    localport: 3389
